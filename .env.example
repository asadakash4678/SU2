# ─── SUMS server configuration ───────────────────────────────
# Copy this file to `.env` and fill in real values before deploying.

# HTTP port the server listens on
PORT=4000

# PostgreSQL connection string (managed cloud DB in production).
# Examples:
#   Local docker:  postgres://sums:sums@localhost:5432/sums
#   Render/Neon/Supabase/RDS: paste the connection string they give you
DATABASE_URL=postgres://sums:sums@localhost:5432/sums

# Set to "true" when your Postgres requires TLS (most managed clouds do)
DATABASE_SSL=false

# Secret used to sign JWT session tokens. MUST be long & random in production.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# How long a login session stays valid
JWT_EXPIRES=12h

# Inactivity auto-logout is enforced client-side; this is the hard token cap above.

# Comma-separated list of allowed browser origins for CORS.
# Use "*" only for local development. In production list your real domain(s).
CORS_ORIGIN=*

# Seed demo data (users + sample patients) on first init. Set false for a clean prod DB.
SEED_DEMO=true
